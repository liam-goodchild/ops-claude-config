#!/usr/bin/env bash
# Global pre-commit: auto-format staged files.
# Activated via: git config --global core.hooksPath ~/.claude/hooks

# terraform fmt
if command -v terraform &>/dev/null; then
	staged_tf=$(git diff --cached --name-only | grep -E '\.(tf|tfvars)$' || true)
	if [ -n "$staged_tf" ]; then
		terraform fmt -recursive . &>/dev/null || true
		while IFS= read -r f; do
			git add "$f"
		done < <(git diff --name-only -- '*.tf' '*.tfvars' 2>/dev/null || true)
	fi
fi

# prettier
if command -v prettier &>/dev/null; then
	staged_fmt=$(git diff --cached --name-only | grep -E '\.(yaml|yml|json)$' || true)
	if [ -n "$staged_fmt" ]; then
		cfg=".github/linters/.prettierrc.json"
		[ ! -f "$cfg" ] && cfg=""
		while IFS= read -r f; do
			prettier --write ${cfg:+--config "$cfg"} "$f" &>/dev/null || true
			git add "$f"
		done <<< "$staged_fmt"
	fi
fi
