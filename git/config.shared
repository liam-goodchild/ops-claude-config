# Shared Git configuration — included by ~/.gitconfig via:
#
#   [include]
#       path = /path/to/ops-claude-config/git/config.shared
#
# Do NOT put credentials, [user], or machine-specific paths here.

[core]
    autocrlf = false
    safecrlf = warn
    whitespace = trailing-space,space-before-tab

[push]
    default = simple
    autoSetupRemote = true

[pull]
    rebase = false

[fetch]
    prune = true

[merge]
    ff = false
    conflictstyle = diff3

[rebase]
    autoStash = true

[diff]
    algorithm = histogram
    colorMoved = default

[log]
    date = iso

[alias]
    st    = status -sb
    co    = checkout
    br    = branch
    lg    = log --oneline --graph --decorate --all
    lp    = log --pretty=format:'%C(yellow)%h%Creset %s %C(dim)(%an, %ar)%Creset'
    undo  = reset --soft HEAD~1
    wip   = !git add -A && git commit -m 'wip [skip ci]'
    sync  = !git fetch --all --prune && git pull
    root  = rev-parse --show-toplevel

[color]
    ui = auto

[init]
    defaultBranch = main
