// Keybindings — symlinked from %APPDATA%\Code\User\keybindings.json
[
  // Open integrated terminal
  {
    "key": "ctrl+`",
    "command": "workbench.action.terminal.toggleTerminal"
  },
  // Format document
  {
    "key": "shift+alt+f",
    "command": "editor.action.formatDocument"
  },
  // Stage current file in source control
  {
    "key": "ctrl+shift+g s",
    "command": "git.stage",
    "when": "editorTextFocus"
  }
]
